<!-- ============================================================
     android/app/src/main/AndroidManifest.xml
     FIXED: May 2026
     
     Changes vs original:
       1. Added WRITE_EXTERNAL_STORAGE (Android ≤ 9 downloads)
       2. Added android:requestLegacyExternalStorage="true"
          (Android 10 scoped-storage workaround)
       3. Added full <queries> block so canLaunchUrl() works on
          Android 11+ for https, mailto, WhatsApp and Telegram.
       4. Added FCM service entry (required for background messages).
       5. Fixed app label typo: "Cs Simplified" → "CS Simplified".
       6. Removed usesCleartextTraffic — backend is HTTPS-only;
          keeping it true is a security risk; comment it back in
          only if you ever add a local-dev HTTP endpoint.
     ============================================================ -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Permissions ──────────────────────────────────────────────────── -->

    <!-- Network (always required) -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Storage — READ is scoped automatically on API 33+, so
         maxSdkVersion keeps the broad permission off modern devices. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>

    <!-- WRITE is needed to copy files to /storage/emulated/0/Download
         on API 21–28.  Scoped storage (API 29+) handles this via
         android:requestLegacyExternalStorage or MediaStore. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29"/>

    <!-- READ_MEDIA_IMAGES: required by image_gallery_saver on Android 13+ (API 33+)
         to save share cards to the device gallery. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>

    <!-- ── Application ──────────────────────────────────────────────────── -->
    <application
        android:label="CS Simplified"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:requestLegacyExternalStorage="true"
        android:hardwareAccelerated="true">
        <!--
            usesCleartextTraffic removed — the backend lives at
            https://cs-api-cqve.onrender.com (HTTPS).  Cleartext is
            unneeded and a security risk.  Restore only for local-dev.
        -->

        <!-- ── Firebase Cloud Messaging background service ──────────────── -->
        <!--
            Without this entry the background message handler registered in
            FcmService.init() is never invoked when the app is killed.
        -->
        <service
            android:name="com.google.firebase.messaging.FirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT"/>
            </intent-filter>
        </service>

        <!-- ── Main Flutter activity ────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>
    </application>

    <!-- ── Android 11+ package visibility ───────────────────────────────── -->
    <!--
        On API 30+ canLaunchUrl() returns FALSE for any scheme not declared
        here, even if the target app is installed.  This is the root cause
        of "Unable to open browser" and the silent WhatsApp/Telegram/email
        failures.  Each <intent> block whitelists one URI scheme.
    -->
    <queries>

        <!-- Any https:// or http:// URL (PDFs in browser, wa.me, t.me) -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="http"/>
        </intent>

        <!-- mailto: links — email client -->
        <intent>
            <action android:name="android.intent.action.SENDTO"/>
            <data android:scheme="mailto"/>
        </intent>

        <!-- WhatsApp native deep-link (whatsapp://send?...) -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="whatsapp"/>
        </intent>

        <!-- Telegram native deep-link (tg://resolve?domain=...) -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="tg"/>
        </intent>

        <!-- Flutter text-processing plugin (keep from original) -->
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>

    </queries>

</manifest>
